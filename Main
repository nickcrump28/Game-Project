def tree():
    art = [
        "                                              .",
        "                                   .         ;",
        "      .              .              ;%     ;;",
        "        ,           ,                :;%  %;",
        "         :         ;                   :;%;'     .,",
        ",.        %;     %;            ;        %;'    ,;",
        "  ;       ;%;  %%;        ,     %;    ;%;    ,%'",
        "   %;       %;%;      ,  ;       %;  ;%;   ,%;'",
        "    ;%;      %;        ;%;        % ;%;  ,%;'",
        "     `%;.     ;%;     %;'         `;%%;.%;'",
        "      `:;%.    ;%%. %@;        %; ;@%;%'",
        "         `:%;.  :;bd%;          %;@%;'",
        "           `@%:.  :;%.         ;@@%;'",
        "             `@%.  `;@%.      ;@@%;",
        "               `@%%. `@%%    ;@@%;",
        "                 ;@%. :@%%  %@@%;",
        "                   %@bd%%%bd%%:;",
        "                     #@%%%%%:;;",
        "                     %@@%%%::;",
        "                     %@@@%(o);  . '",
        "                     %@@@o%;:(.,'",
        "                 `.. %@@@o%::;",
        "                    `)@@@o%::;",
        "                     %@@(o)::;",
        "                    .%@@@@%::;",
        "                    ;%@@@@%::;.",
        "                   ;%@@@@%%:;;;.",
        "               ...;%@@@@@%%:;;;;,.."
    ]
    for line in art:
        print(line)
        time.sleep(0.05)
    print(" ")

